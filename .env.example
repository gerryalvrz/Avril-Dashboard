NEXT_PUBLIC_CONVEX_URL=
# Deployment slug only, e.g. dev:happy-animal-123 — never paste dashboard URLs or tokens after a |
CONVEX_DEPLOYMENT=
# Shared secret for Next.js API → Convex (serverChats, bootstrap). Generate once, set in Convex AND .env.local:
#   openssl rand -base64 32
#   npx convex env set CONVEX_SERVER_SECRET "<paste-here>"
CONVEX_SERVER_SECRET=
HUMAN_TECH_PROJECT_ID=
HUMAN_TECH_CLIENT_ID=
HUMAN_TECH_CLIENT_SECRET=
AA_PROVIDER_API_KEY=
SENTRY_DSN=
DASHBOARD_APP_TOKEN=
NEXT_PUBLIC_DASHBOARD_APP_TOKEN=
OPENCLAW_BRIDGE_URL=
OPENCLAW_ALLOWED_BRIDGE_URL=https://openclaw.agents.motusdao.org/respond
OPENCLAW_BRIDGE_TOKEN=
# `next dev` only: use local bridge so chat/spawn work without public OpenClaw DNS
# OPENCLAW_BRIDGE_URL_DEV=http://127.0.0.1:8787/respond
NEXT_PUBLIC_OWNER_WALLET=
NEXT_PUBLIC_WAAP_LOGO=
# ERC-8004 agent identity (Celo). Production: https://app.avril.life
NEXT_PUBLIC_APP_URL=https://app.avril.life
NEXT_PUBLIC_AGENT_REGISTRATION_URI=https://app.avril.life/agent-registration.json
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org
# Startup Agent Generator (Prism + ENS + ERC-8004 optional hooks)
PRISM_KEYS_DIR=~/.config/prism/keys
PRISM_ROOT_KEY_PATH=~/.config/prism/keys/root-wallet.json
PRISM_ROOT_PRIVATE_KEY=
PRISM_FACTORY_ADDRESS=
PRISM_CONTEXT_ADDRESS=
ENS_REGISTRY_ADDRESS=
STARTUP_AGENT_DEFAULT_FUNDING_CELO=0.01
STARTUP_AGENT_REGISTER_8004=0
ERC8004_REGISTRY_ADDRESS=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
STARTUP_AGENT_8004_URI_BASE=https://app.avril.life
# After first onchain registration, set for domain proof at /.well-known/agent-registration.json
NEXT_PUBLIC_ERC8004_AGENT_ID=
NEXT_PUBLIC_ERC8004_AGENT_OWNER=
NEXT_PUBLIC_PASSPORT_EMBED_API_KEY=
NEXT_PUBLIC_PASSPORT_SCORER_ID=

# Server-side Passport score verification (recommended)
PASSPORT_API_KEY=
PASSPORT_SCORER_ID=
PASSPORT_SCORE_THRESHOLD=20
